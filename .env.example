# Postgres
POSTGRES_DB=maskproxy
POSTGRES_USER=maskproxy
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://maskproxy:changeme@db:5432/maskproxy

# Redis
REDIS_URL=redis://cache:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars

# Provider Keys
# generate using python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" in terminal
MASTER_ENCRYPTION_KEY=your_generated_key_here

# Proxy upstream
UPSTREAM_BASE_URL=https://api.openai.com
UPSTREAM_API_KEY=
MAPPING_TTL_SECONDS=3600
MAX_BODY_BYTES=1048576
ROUTING_ENABLED=false
LOCAL_UPSTREAM_BASE_URL=
ROUTING_STRATEGY=keyword
ROUTING_DEFAULT_TARGET=cloud
ROUTING_LOCAL_KEYWORDS=medical,patient,diagnosis,bank account,ssn,financial
ROUTING_SIMILARITY_THRESHOLD=0.8
ROUTING_TOP_K=3
ROUTING_EMBEDDING_BACKEND=onnx
ROUTING_EMBEDDING_MODEL_ID=
ROUTING_EMBEDDING_MODEL_PATH=
ROUTING_EMBEDDING_TOKENIZER_PATH=
ROUTING_EMBEDDING_PROVIDERS=CPUExecutionProvider
ROUTING_STORE_BACKEND=memory
ROUTING_EXAMPLES_PATH=
ROUTING_LANCEDB_URI=data/lancedb
ROUTING_LANCEDB_TABLE=route_examples
NER_ENABLED=false
NER_BACKEND=none
NER_MODEL_ID=
NER_DEVICE=-1
NER_HF_TOKEN=
NER_ONNX_MODEL_PATH=
NER_ONNX_TOKENIZER_PATH=
NER_ONNX_LABELS_PATH=
NER_ONNX_PROVIDERS=CPUExecutionProvider
NER_CONFIDENCE_THRESHOLD=0.75
